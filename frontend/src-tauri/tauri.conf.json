{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "食堂仓库管理系统",
  "version": "0.1.0",
  "identifier": "com.cims.warehouse",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "食堂仓库管理系统",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "resources": ["../../backend/dist/cims-backend.exe"]
  }
}
